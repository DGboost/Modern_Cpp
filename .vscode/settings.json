{
    "cmake.configureOnOpen": false,
    "cmake.preferredGenerators": [
        "Ninja"
    ],
    "clangd.arguments": [
        "--background-index",
        "--header-insertion=never"
    ],
    "editor.formatOnSave": true,
    "[cpp]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
    },
    "[c]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
    }
}